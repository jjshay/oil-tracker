# ─────────────────────────────────────────────────────────────────────────────
# TradeRadar — daily briefing environment template
#
# Usage:
#   cp scripts/.env.example .env        (the script loads .env from the REPO ROOT,
#                                        not from scripts/. .env is gitignored.)
#   Edit the real .env with actual values, then: npm install && npm run briefing
#
# All LLM keys are OPTIONAL — the script gracefully skips any provider whose
# key is missing. Finnhub key is OPTIONAL — portfolio section is skipped if
# absent. Only GMAIL_USER + GMAIL_APP_PW are strictly required to send email.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gmail (REQUIRED) ─────────────────────────────────────────────────────────
# GMAIL_APP_PW must be a 16-char Gmail App Password — NOT your regular login pw.
# Create at:  https://myaccount.google.com/apppasswords
# Prereq:     2-Step Verification must already be enabled on the Google account.
# Paste the 16 chars with or without spaces; Google accepts both.
GMAIL_USER=jjshay@gmail.com
GMAIL_APP_PW=your-gmail-app-pw-here

# Recipient. Defaults to jjshay@gmail.com if unset.
TO_EMAIL=jjshay@gmail.com

# ── LLM providers (OPTIONAL — set the ones you want in the consensus block) ─
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI (GPT)       — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Google (Gemini)    — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# xAI (Grok)         — https://console.x.ai/
XAI_API_KEY=your-xai-key-here

# ── Market data (OPTIONAL — enables the live portfolio quotes block) ────────
# Finnhub — https://finnhub.io/dashboard  (free tier is fine for 5 symbols)
FINNHUB_API_KEY=your-finnhub-key-here
