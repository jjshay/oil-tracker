# ─────────────────────────────────────────────────────────────────────────────
# TradeRadar — repo-root .env template
#
# The briefing script (scripts/daily-briefing.js) loads .env from THIS directory
# (the repo root), not from scripts/. Copy this file to `.env` and fill values.
#
#     cp .env.example .env
#
# .env is gitignored. All LLM keys are OPTIONAL (providers with missing keys
# are skipped). Only GMAIL_USER + GMAIL_APP_PW are strictly required.
# See scripts/.env.example for the full reference with per-key sign-up links.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gmail (REQUIRED) ─────────────────────────────────────────────────────────
# 16-char Gmail App Password (NOT your regular login pw).
# Create: https://myaccount.google.com/apppasswords (2-Step Verification required).
GMAIL_USER=jjshay@gmail.com
GMAIL_APP_PW=your-gmail-app-pw-here

# Recipient (defaults to jjshay@gmail.com if unset).
TO_EMAIL=jjshay@gmail.com

# ── LLM providers (OPTIONAL) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here    # https://console.anthropic.com/settings/keys
OPENAI_API_KEY=your-openai-key-here          # https://platform.openai.com/api-keys
GEMINI_API_KEY=your-gemini-key-here          # https://aistudio.google.com/app/apikey
XAI_API_KEY=your-xai-key-here                # https://console.x.ai/

# ── Market data (OPTIONAL — enables portfolio quote block) ──────────────────
FINNHUB_API_KEY=your-finnhub-key-here        # https://finnhub.io/dashboard
